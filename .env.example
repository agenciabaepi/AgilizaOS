# Copie para .env.local e preencha com valores reais (nunca commite segredos)

MERCADOPAGO_ACCESS_TOKEN="seu_token_mercadopago"
MERCADOPAGO_ENVIRONMENT="sandbox"

NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_do_supabase
NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_do_supabase"

# Token OIDC da Vercel (gerado no deploy/CLI; não versionar valor real)
VERCEL_OIDC_TOKEN=""

# OpenAI (ChatGPT) - obrigatório para correção de laudo técnico com IA (/api/laudo/corrigir)
OPENAI_API_KEY=sk-...

# BrasilSMS — confirmação de cadastro por SMS
BRASILSMS_API_TOKEN=
BRASILSMS_API_URL=https://api.brasilsms.com

NEXT_PUBLIC_SITE_URL=https://gestaoconsert.com.br
PLATFORM_ADMIN_EMAILS=admin@exemplo.com
ADMIN_SAAS_ACCESS_CODE=
ADMIN_SAAS_OPEN=1

# SaaS / cobrança: após rodar database/saas_billing_functions.sql no Supabase, o middleware chama a RPC.
# SAAS_SKIP_BILLING_RPC=1
# Fuso para trial e vencimento no servidor (deve bater com o SQL; padrão America/Sao_Paulo)
# NEXT_PUBLIC_BILLING_TZ=America/Sao_Paulo
